{
  "description": "FSCA CLI - 链上智能合约集群开发工具",
  "commands": {
    "help": {
      "description": "显示帮助信息",
      "handler": "./libs/commands/help",
      "usage": "fsca help"
    },
    "deploy": {
      "description": "继承自部署标准合约模板 (NormalTemplate)",
      "handler": "./libs/commands/deploy",
      "usage": "fsca deploy <description>",
      "params": {
        "description": {
          "type": "string",
          "required": true,
          "description": "合约描述/名称"
        }
      }
    },
    "init": {
      "description": "初始化 FSCA 项目",
      "handler": "./libs/commands/init/init",
      "usage": "fsca init [--networkName <name>] [--rpc <url>] [--chainId <id>] [--blockConfirmations <num>] [--accountPrivateKey <key>] [--address <addr>]",
      "params": {
        "networkName": {
          "type": "string",
          "required": false,
          "description": "网络名称"
        },
        "rpc": {
          "type": "string",
          "required": false,
          "description": "RPC URL"
        },
        "chainId": {
          "type": "number",
          "required": false,
          "description": "链 ID"
        },
        "blockConfirmations": {
          "type": "number",
          "required": false,
          "description": "区块确认数"
        },
        "accountPrivateKey": {
          "type": "string",
          "required": false,
          "description": "账户私钥"
        },
        "address": {
          "type": "string",
          "required": false,
          "description": "钱包地址"
        }
      }
    },
    "wallet": {
      "description": "管理 MultiSig 钱包",
      "commands": {
        "submit": {
          "description": "提交新交易到多签钱包",
          "handler": "./libs/commands/wallet/submit",
          "usage": "fsca wallet submit --to <address> --value <amount> --data <hex>",
          "params": {
            "to": {
              "type": "string",
              "required": true,
              "description": "目标合约地址"
            },
            "value": {
              "type": "string",
              "required": false,
              "description": "发送的 ETH 数量 (默认 0)"
            },
            "data": {
              "type": "string",
              "required": true,
              "description": "调用数据 (ABI 编码的 hex)"
            }
          }
        },
        "confirm": {
          "description": "确认待处理的交易",
          "handler": "./libs/commands/wallet/confirm",
          "usage": "fsca wallet confirm <txIndex>",
          "params": {
            "txIndex": {
              "type": "number",
              "required": true,
              "description": "交易索引"
            }
          }
        },
        "execute": {
          "description": "执行已达到阈值的交易",
          "handler": "./libs/commands/wallet/execute",
          "usage": "fsca wallet execute <txIndex>",
          "params": {
            "txIndex": {
              "type": "number",
              "required": true,
              "description": "交易索引"
            }
          }
        },
        "revoke": {
          "description": "撤销之前的确认",
          "handler": "./libs/commands/wallet/revoke",
          "usage": "fsca wallet revoke <txIndex>",
          "params": {
            "txIndex": {
              "type": "number",
              "required": true,
              "description": "交易索引"
            }
          }
        },
        "list": {
          "description": "列出所有交易",
          "handler": "./libs/commands/wallet/list",
          "usage": "fsca wallet list [--pending]",
          "params": {
            "pending": {
              "type": "boolean",
              "required": false,
              "description": "仅显示待处理的交易"
            }
          }
        },
        "info": {
          "description": "查看交易详情",
          "handler": "./libs/commands/wallet/info",
          "usage": "fsca wallet info <txIndex>",
          "params": {
            "txIndex": {
              "type": "number",
              "required": true,
              "description": "交易索引"
            }
          }
        },
        "owners": {
          "description": "查看所有所有者和阈值",
          "handler": "./libs/commands/wallet/owners",
          "usage": "fsca wallet owners"
        },
        "propose": {
          "description": "提议治理变更",
          "commands": {
            "add-owner": {
              "description": "提议添加新所有者",
              "handler": "./libs/commands/wallet/propose",
              "usage": "fsca wallet propose add-owner <address>",
              "params": {
                "address": {
                  "type": "string",
                  "required": true,
                  "description": "新所有者地址"
                }
              }
            },
            "remove-owner": {
              "description": "提议移除所有者",
              "handler": "./libs/commands/wallet/propose",
              "usage": "fsca wallet propose remove-owner <address>",
              "params": {
                "address": {
                  "type": "string",
                  "required": true,
                  "description": "要移除的所有者地址"
                }
              }
            },
            "change-threshold": {
              "description": "提议修改确认阈值",
              "handler": "./libs/commands/wallet/propose",
              "usage": "fsca wallet propose change-threshold <threshold>",
              "params": {
                "threshold": {
                  "type": "number",
                  "required": true,
                  "description": "新的确认阈值"
                }
              }
            }
          }
        }
      }
    },
    "cluster": {
      "description": "FSCA 集群相关命令",
      "commands": {
        "init": {
          "description": "部署 FSCA 集群",
          "handler": "./libs/commands/cluster/init",
          "usage": "fsca cluster init [--threshold <num>]",
          "params": {
            "threshold": {
              "type": "number",
              "required": false,
              "description": "多签钱包所需确认数（默认：1）"
            }
          }
        },
        "graph": {
          "description": "生成集群拓扑图 (Mermaid)",
          "handler": "./libs/commands/cluster/graph",
          "usage": "fsca cluster graph"
        },
        "list": {
          "description": "列举全局合约集群",
          "commands": {
            "mounted": {
              "description": "列举已挂载的合约",
              "handler": "./libs/commands/cluster/list",
              "usage": "fsca cluster list mounted"
            },
            "all": {
              "description": "列举所有合约（包括已删除的）",
              "handler": "./libs/commands/cluster/list",
              "usage": "fsca cluster list all"
            }
          }
        },
        "info": {
          "description": "查询集群合约详情 (by ID)",
          "handler": "./libs/commands/cluster/info",
          "usage": "fsca cluster info <id>",
          "params": {
            "id": {
              "type": "number",
              "required": true,
              "description": "合约ID"
            }
          }
        },
        "current": {
          "description": "显示当前操作的合约信息",
          "handler": "./libs/commands/cluster/current",
          "usage": "fsca cluster current"
        },
        "operator": {
          "description": "管理集群管理员 (Operator)",
          "commands": {
            "list": {
              "description": "列出所有 Operator",
              "handler": "./libs/commands/cluster/operator",
              "usage": "fsca cluster operator list"
            },
            "add": {
              "description": "添加 Operator",
              "handler": "./libs/commands/cluster/operator",
              "usage": "fsca cluster operator add <address>",
              "params": {
                "address": {
                  "type": "string",
                  "required": true,
                  "description": "Operator 地址"
                }
              }
            },
            "remove": {
              "description": "移除 Operator",
              "handler": "./libs/commands/cluster/operator",
              "usage": "fsca cluster operator remove <address>",
              "params": {
                "address": {
                  "type": "string",
                  "required": true,
                  "description": "Operator 地址"
                }
              }
            }
          }
        },
        "choose": {
          "description": "选择当前操作的合约",
          "handler": "./libs/commands/cluster/choose",
          "usage": "fsca cluster choose <address>",
          "params": {
            "address": {
              "type": "string",
              "required": true,
              "description": "合约地址"
            }
          }
        },
        "link": {
          "description": "链接合约(仅未挂载时可用)",
          "handler": "./libs/commands/cluster/link",
          "usage": "fsca cluster link <type> <targetAddress> <targetId>",
          "params": {
            "type": {
              "type": "string",
              "required": true,
              "description": "链接类型: positive 或 passive"
            },
            "targetAddress": {
              "type": "string",
              "required": true,
              "description": "目标合约地址"
            },
            "targetId": {
              "type": "number",
              "required": true,
              "description": "目标合约ID"
            }
          }
        },
        "unlink": {
          "description": "解除合约链接 (需要合约已挂载)",
          "handler": "./libs/commands/cluster/unlink",
          "usage": "fsca cluster unlink <type> <targetAddress> <targetId>",
          "params": {
            "type": {
              "type": "string",
              "required": true,
              "description": "链接类型: positive 或 passive"
            },
            "targetAddress": {
              "type": "string",
              "required": true,
              "description": "目标合约地址"
            },
            "targetId": {
              "type": "number",
              "required": true,
              "description": "目标合约ID"
            }
          }
        },
        "mount": {
          "description": "将当前合约挂载到集群",
          "handler": "./libs/commands/cluster/mount",
          "usage": "fsca cluster mount <id> <name>",
          "params": {
            "id": {
              "type": "number",
              "required": true,
              "description": "合约ID (唯一标识)"
            },
            "name": {
              "type": "string",
              "required": true,
              "description": "合约名称"
            }
          }
        },
        "unmount": {
          "description": "从集群卸载合约",
          "handler": "./libs/commands/cluster/unmount",
          "usage": "fsca cluster unmount <id>",
          "params": {
            "id": {
              "type": "number",
              "required": true,
              "description": "要卸载的合约ID"
            }
          }
        }
      }
    },
    "normal": {
      "description": "标准合约(NormalTemplate)相关命令",
      "commands": {
        "right": {
          "description": "管理合约 ABI 权限 (通过 ClusterManager)",
          "commands": {
            "set": {
              "description": "设置 ABI 权限等级",
              "handler": "./libs/commands/normal/right",
              "usage": "fsca normal right set <abiId> <maxRight>",
              "params": {
                "abiId": {
                  "type": "string",
                  "required": true,
                  "description": "ABI ID/Hash"
                },
                "maxRight": {
                  "type": "string",
                  "required": true,
                  "description": "最大权限等级 (整数)"
                }
              }
            },
            "remove": {
              "description": "移除 ABI 权限",
              "handler": "./libs/commands/normal/right",
              "usage": "fsca normal right remove <abiId>",
              "params": {
                "abiId": {
                  "type": "string",
                  "required": true,
                  "description": "ABI ID/Hash"
                }
              }
            }
          }
        },
        "get": {
          "description": "查询合约信息",
          "commands": {
            "modules": {
              "description": "获取已链接的模块",
              "handler": "./libs/commands/normal/get",
              "usage": "fsca normal get modules <type>",
              "params": {
                "type": {
                  "type": "string",
                  "required": true,
                  "description": "active 或 passive"
                }
              }
            }
          }
        }
      }
    }
  }
}